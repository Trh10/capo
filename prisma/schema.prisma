generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum DeviceType {
  WEB
  MOBILE
  DESKTOP
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
}

enum DownloadStatus {
  PENDING
  READY
  EXPIRED
  REVOKED
}

enum LessonContentType {
  VIDEO
  DOCUMENT
  BOOK
  SYLLABUS
  AUDIO
  RESOURCE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole  @default(STUDENT)
  emailVerified Boolean   @default(false)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  devices       Device[]
  purchases     Purchase[]
  downloads     Download[]
  progress      LessonProgress[]
  teacherProfile Teacher?

  @@index([email])
}

model Teacher {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  specialty   String?
  location    String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses     Course[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  courses     Course[]
}

model Course {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  shortDesc     String?
  thumbnailUrl  String?
  price         Int      // en centimes (ex: 1999 = 19,99 €)
  level         String   @default("Débutant")
  duration      Int      @default(0) // durée totale en minutes
  isPublished   Boolean  @default(false)
  teacherId     String
  categoryId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  category      Category? @relation(fields: [categoryId], references: [id])
  lessons       Lesson[]
  purchases     Purchase[]

  @@index([slug])
  @@index([teacherId])
  @@index([isPublished])
}

model Lesson {
  id          String            @id @default(cuid())
  title       String
  slug        String
  description String?
  contentType LessonContentType @default(VIDEO)
  videoUrl    String?
  duration    Int               @default(0) // en secondes
  order       Int
  isFree      Boolean           @default(false)
  courseId    String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  downloads   Download[]

  @@unique([courseId, slug])
  @@index([courseId, order])
}

model Device {
  id           String     @id @default(cuid())
  userId       String
  name         String
  type         DeviceType
  fingerprint  String
  lastActiveAt DateTime   @default(now())
  createdAt    DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  downloads    Download[]

  @@unique([userId, fingerprint])
  @@index([userId])
}

model Purchase {
  id              String         @id @default(cuid())
  userId          String
  courseId        String
  amount          Int
  status          PurchaseStatus @default(PENDING)
  stripePaymentId String?        @unique
  purchasedAt     DateTime       @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Download {
  id           String         @id @default(cuid())
  userId       String
  lessonId     String
  deviceId     String
  status       DownloadStatus @default(PENDING)
  licenseKey   String         @unique
  expiresAt    DateTime?
  downloadedAt DateTime?
  createdAt    DateTime       @default(now())

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  device       Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId, deviceId])
  @@index([userId])
  @@index([deviceId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  watchedSec  Int      @default(0)
  completed   Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}
