# Base de données
# Local (PostgreSQL via Docker) : postgresql://capo:motdepasse@localhost:5432/capo
# Production Coolify : généré automatiquement par docker-compose
DATABASE_URL="postgresql://capo:changez-moi@localhost:5432/capo"
# Secret JWT pour les sessions (générer une clé aléatoire en production)
JWT_SECRET="changez-moi-en-production-avec-une-cle-secrete-longue"

# Stripe — https://dashboard.stripe.com/test/apikeys
# En local sans clés : achat simulé automatiquement
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# URL de l'application (pour les redirections Stripe)
NEXT_PUBLIC_APP_URL="http://localhost:3002"
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
